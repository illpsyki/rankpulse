// ===========================
//  RankPulse Database Schema
// ===========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription  Subscription?
  reports       Report[]
  apiKeys       ApiKey[]
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  stripeSubId     String?   @unique
  plan            String    // "free" | "pro" | "agency"
  status          String    // "active" | "canceled" | "past_due"
  currentPeriodEnd DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id            String    @id @default(cuid())
  userId        String
  url           String
  title         String?
  description   String?
  overallScore  Int       @default(0)
  // Category scores
  performance   Int       @default(0)
  accessibility Int       @default(0)
  seo           Int       @default(0)
  mobile        Int       @default(0)
  // Meta checks
  metaTitle     String?
  metaDescription String?
  metaKeywords  String?
  canonical     String?
  ogTags        String?
  h1Count       Int       @default(0)
  h2Count       Int       @default(0)
  // Technical
  https         Boolean   @default(false)
  mobileOptimized Boolean @default(false)
  sitemap       Boolean   @default(false)
  robotsTxt     Boolean   @default(false)
  pageLoadTime  Float     @default(0)
  pageSize      Float     @default(0)
  imageCount    Int       @default(0)
  imagesWithoutAlt Int    @default(0)
  linkCount     Int       @default(0)
  brokenLinks   Int       @default(0)
  // Content
  wordCount     Int       @default(0)
  hasStructuredData Boolean @default(false)
  // AI suggestions
  aiSuggestions String?   // JSON string of AI recommendations
  htmlSnapshot  String?   // raw HTML for analysis
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  userId      String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  stripePaymentId String    @unique
  amount          Int
  currency        String    @default("usd")
  status          String
  createdAt       DateTime  @default(now())
}
